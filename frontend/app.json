{
  "expo": {
    "name": "Arrow Escape",
    "slug": "arrow-escape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arrowescape",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arrowescape.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Allows us to show ads that are relevant to you so we can keep Arrow Escape free.",
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" }
        ]
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.arrowescape.app",
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "689dadc5-a202-4770-b51c-b74dc4c20b03"
      }
    }
  }
}
